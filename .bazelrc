# Windows TLS fix - loaded only when .bazelrc.windows exists (local-only file)
try-import .bazelrc.windows

# Auto-shutdown the Bazel server after 5 minutes of inactivity to avoid
# zombie JVM processes holding file locks on Windows.
startup --max_idle_secs=300

# Stop Bazel from creating the convenience symlinks (bazel-bin, bazel-out,
# bazel-testlogs, bazel-<workspace>) at the repo root. The real outputs
# still live under .bazel-output/ (see startup flag above); we just don't
# want four extra symlinks cluttering the workspace / git status.
build --experimental_convenience_symlinks=ignore

# Common settings
build --java_language_version=21
build --java_runtime_version=remotejdk_21

# Show which tests have oversized timeout/size declarations
test --test_verbose_timeout_warnings

# Always re-run coverage without cached test results
coverage --nocache_test_results

# --- Module 7: Named Configs ---

# Default: write BES output to a local JSON file for inspection
build --build_event_json_file=build_events.json

# CI config: strict, no local cache writes
build:ci --keep_going
build:ci --noremote_upload_local_results
build:ci --build_event_json_file=build_events_ci.json
test:ci --test_output=errors

# Debug config
build:debug -c dbg
build:debug --strip=never

# AddressSanitizer config (C/C++ only)
build:asan -c dbg
build:asan --strip=never
build:asan --copt=-fsanitize=address
build:asan --copt=-fno-omit-frame-pointer
build:asan --linkopt=-fsanitize=address